---
services:
  db:
    image: {{ n8n_pg_image }}
    restart: unless-stopped
    environment:
      POSTGRES_DB: "{{ n8n_db_name }}"
      POSTGRES_USER: "{{ n8n_db_user }}"
      POSTGRES_PASSWORD: "{{ n8n_db_password }}"
    volumes:
      - {{ n8n_pg_data_dir }}:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ n8n_db_user }} -d {{ n8n_db_name }}"]
      interval: 10s
      timeout: 5s
      retries: 5

  n8n:
    image: {{ n8n_image }}
    restart: unless-stopped
    ports:
      - "{{ n8n_port }}:5678"
    depends_on:
      db:
        condition: service_healthy
    volumes:
      - {{ n8n_data_dir }}:/home/node/.n8n
    environment:
      DB_TYPE: postgresdb
      DB_POSTGRESDB_HOST: db
      DB_POSTGRESDB_PORT: "5432"
      DB_POSTGRESDB_DATABASE: "{{ n8n_db_name }}"
      DB_POSTGRESDB_USER: "{{ n8n_db_user }}"
      DB_POSTGRESDB_PASSWORD: "{{ n8n_db_password }}"
      WEBHOOK_URL: "https://{{ n8n_domain }}/"
      GENERIC_TIMEZONE: "{{ n8n_timezone }}"
      N8N_RUNNERS_ENABLED: "{{ n8n_runners_enabled | lower }}"
      N8N_RUNNERS_MAX_PAYLOAD: "536870912"
      EXECUTIONS_DATA_PRUNE: "{{ n8n_executions_prune | lower }}"
      EXECUTIONS_DATA_MAX_AGE: "{{ n8n_executions_prune_max_age }}"
      N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS: "true"
      N8N_DIAGNOSTICS_ENABLED: "{{ n8n_diagnostics_enabled | lower }}"
      N8N_METRICS: "false"
{% if n8n_watchtower_enabled | bool %}

  watchtower:
    image: {{ n8n_watchtower_image }}
    restart: unless-stopped
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    environment:
      WATCHTOWER_POLL_INTERVAL: "{{ n8n_watchtower_interval }}"
{% endif %}
