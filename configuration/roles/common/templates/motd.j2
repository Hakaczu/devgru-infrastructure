printf "         %s\n\n" "{{ common_motd_greeting }}"
printf "         Host : %s\n" "$(hostname -s)"
printf "         OS   : %s\n\n" "$(. /etc/os-release 2>/dev/null && printf '%s' "${PRETTY_NAME:-Unknown}")"

# Live Noospheric Telemetry
load=$(cut -d' ' -f1 /proc/loadavg)
procs=$(ls -d /proc/[0-9]* 2>/dev/null | wc -l)
mem_total=$(awk '/MemTotal/{print $2}' /proc/meminfo)
mem_avail=$(awk '/MemAvailable/{print $2}' /proc/meminfo)
mem_pct=$(( (mem_total - mem_avail) * 100 / mem_total ))
swap_total=$(awk '/SwapTotal/{print $2}' /proc/meminfo)
swap_free=$(awk '/SwapFree/{print $2}' /proc/meminfo)
[ "$swap_total" -gt 0 ] && swap_pct=$(( (swap_total - swap_free) * 100 / swap_total )) || swap_pct=0
disk=$(df -h / | awk 'NR==2 {printf "%s of %s (%s)", $3, $2, $5}')
ipv4=$(ip -4 route get 1 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="src"){print $(i+1);exit}}')
ipv6=$(ip -6 route get ::1 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="src"){print $(i+1);exit}}')
users=$(who | wc -l | tr -d ' ')
temp_str=""
for zone in /sys/class/thermal/thermal_zone*/temp; do
    [ -f "$zone" ] && temp_str=$(awk '{printf "%.1f C", $1/1000}' "$zone") && break
done

printf "  %-34s  %s\n" "  Cogitator Strain   : $load"        "Active Subroutines : $procs"
printf "  %-34s  %s\n" "  Engram Banks       : ${mem_pct}%"  "Sanctioned Adepts  : $users"
if [ -n "$temp_str" ]; then
    printf "  %-34s  %s\n" "  Overflow Buffer    : ${swap_pct}%" "Plasma Coolant     : $temp_str"
else
    printf "  %s\n"         "  Overflow Buffer    : ${swap_pct}%"
fi
printf "  Data-Vault Capacity  : %s\n" "$disk"
printf "  Noospheric IPv4      : %s\n" "${ipv4:-N/A}"
printf "  Noospheric IPv6      : %s\n\n" "${ipv6:-N/A}"
printf "         %s\n\n" "{{ common_motd_footer }}"
